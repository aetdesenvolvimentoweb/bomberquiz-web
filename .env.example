# Vazio = usa o proxy do Vite dev server (server.proxy em vite.config.ts) contra
# http://localhost:3000, evitando o problema de cookie cross-origin em dev (SameSite=Lax
# não é enviado em fetch cross-site fora de navegação top-level). Em produção, defina a
# URL absoluta do backend implantado (ex.: https://api.bomberquiz.com.br).
VITE_API_BASE_URL=
